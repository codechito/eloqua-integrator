<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>Configure Incoming SMS Feeder</title>

    <link href="/eloqua-service/assets/css/bootstrap.min.css" rel="stylesheet">
    <link href="/eloqua-service/assets/css/main.css" rel="stylesheet">
    <style type="text/css">
      @keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
      }

      .spinner {
        border: 3px solid #f3f3f3;
        border-top: 3px solid #4CAF50;
        border-radius: 50%;
        width: 30px;
        height: 30px;
        animation: spin 1s linear infinite;
        display: inline-block;
        margin-right: 10px;
      }

      .spinner-sm {
        width: 16px;
        height: 16px;
        border-width: 2px;
        margin-right: 5px;
        vertical-align: middle;
      }

      body {
        font-family: Arial, sans-serif;
        padding: 0;
        margin: 0;
      }

      .container {
        max-width: 700px;
        margin: 40px auto;
        padding: 30px;
        background: #fff;
      }

      h4 {
        font-size: 20px;
        font-weight: bold;
        text-align: center;
        margin-bottom: 30px;
      }

      h4 img {
        vertical-align: middle;
        margin-right: 10px;
      }

      .form-group {
        margin-bottom: 20px;
      }

      .form-group label {
        display: block;
        font-weight: bold;
        margin-bottom: 8px;
        font-size: 14px;
      }

      .form-control {
        width: 100%;
        padding: 10px;
        border: 1px solid #ddd;
        border-radius: 4px;
        font-size: 14px;
        box-sizing: border-box;
        height: 40px;
      }

      .form-control:focus {
        outline: none;
        border-color: #007bff;
      }

      .help-text {
        font-size: 12px;
        color: #666;
        margin-top: 5px;
        line-height: 1.4;
      }

      .btn {
        padding: 12px 30px;
        background: #007bff;
        color: white;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-size: 14px;
        font-weight: bold;
        width: 100%;
        margin-top: 10px;
      }

      .btn:hover {
        background: #0056b3;
      }

      .btn:disabled {
        background: #ccc;
        cursor: not-allowed;
      }

      .btn-default {
        background: #fff;
        color: #333;
        border: 1px solid #ccc;
        width: auto;
        padding: 8px 20px;
        font-size: 13px;
      }

      .btn-default:hover {
        background: #e6e6e6;
      }

      .alert {
        padding: 12px 15px;
        border-radius: 4px;
        margin-bottom: 20px;
        font-size: 14px;
      }

      .alert-success {
        background: #d4edda;
        border: 1px solid #c3e6cb;
        color: #155724;
      }

      .alert-danger {
        background: #f8d7da;
        border: 1px solid #f5c6cb;
        color: #721c24;
      }

      .alert.fade {
        opacity: 0;
        transition: opacity 0.5s ease-in-out;
      }

      .alert.fade.in {
        opacity: 1;
      }

      .info-box {
        background: #e7f3ff;
        border-left: 4px solid #007bff;
        padding: 15px;
        margin-bottom: 20px;
        border-radius: 4px;
      }

      .info-box p {
        margin: 0;
        font-size: 13px;
        line-height: 1.6;
        color: #004085;
      }

      .info-box strong {
        display: block;
        margin-bottom: 5px;
      }

      .section-divider {
        border-top: 2px solid #dee2e6;
        margin: 30px 0;
      }

      .cdo-mapping-box {
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 4px;
        padding: 15px;
        margin-bottom: 20px;
      }

      .cdo-mapping-box h5 {
        margin: 0 0 15px 0;
        font-size: 15px;
        font-weight: bold;
        color: #495057;
        border-bottom: 2px solid #dee2e6;
        padding-bottom: 8px;
      }

      .cdo-field-row {
        display: flex;
        justify-content: space-between;
        padding: 8px 0;
        border-bottom: 1px solid #e9ecef;
        font-size: 13px;
      }

      .cdo-field-row:last-child {
        border-bottom: none;
      }

      .cdo-field-label {
        font-weight: 600;
        color: #6c757d;
        flex: 0 0 40%;
      }

      .cdo-field-value {
        color: #212529;
        flex: 1;
        text-align: right;
        font-family: 'Courier New', monospace;
      }

      .cdo-no-config {
        text-align: center;
        color: #6c757d;
        font-style: italic;
        padding: 10px;
      }

      .cdo-name {
        background: #007bff;
        color: white;
        padding: 8px 12px;
        border-radius: 4px;
        margin-bottom: 15px;
        font-size: 13px;
        font-weight: bold;
      }

      .report-section {
        background: #fff;
        border: 1px solid #dee2e6;
        border-radius: 4px;
        padding: 15px;
        margin-bottom: 15px;
      }

      .report-section h5 {
        margin: 0 0 15px 0;
        font-size: 15px;
        font-weight: bold;
        color: #495057;
        border-bottom: 2px solid #dee2e6;
        padding-bottom: 8px;
      }

      .report-stats {
        display: flex;
        justify-content: space-around;
        margin-bottom: 15px;
        padding: 15px;
        background: #f8f9fa;
        border-radius: 4px;
      }

      .stat-card {
        text-align: center;
        flex: 1;
      }

      .stat-card .stat-number {
        font-size: 32px;
        font-weight: bold;
        color: #007bff;
        display: block;
      }

      .stat-card .stat-label {
        font-size: 12px;
        color: #6c757d;
        text-transform: uppercase;
        margin-top: 5px;
        display: block;
      }

      .stat-card.success .stat-number { color: #28a745; }
      .stat-card.warning .stat-number { color: #ffc107; }

      .loading-spinner {
        text-align: center;
        padding: 20px;
        color: #6c757d;
      }

      .report-actions {
        text-align: center;
        padding-top: 10px;
        border-top: 1px solid #dee2e6;
      }

      .number-status {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 12px;
        font-size: 11px;
        font-weight: bold;
        margin-left: 8px;
        vertical-align: middle;
      }

      .number-status.configured {
        background: #d4edda;
        color: #155724;
      }

      .number-status.not-configured {
        background: #fff3cd;
        color: #856404;
      }
    </style>
  </head>
  <body>
    <div class="container" id="incomingsmsfeeder">
      <form method="post">
        <h4>
          <img src="/eloqua-service/assets/images/eloqua-form-icon-inbound.png" width="24" height="24" onerror="this.style.display='none'">
          Incoming SMS Feeder
        </h4>

        <div v-if="status.success || status.error"
             v-bind:class="{ 'alert-success': status.success, 'alert-danger': status.error, 'in': fade }"
             class="alert fade"
             role="alert">
          {{ status.success || status.error }}
        </div>

        <div class="info-box">
          <p>
            <strong>How this works</strong>
            Select a virtual number to monitor. When someone texts that number, they will be
            fed into the next step of your campaign. Optionally filter by a keyword so only
            messages containing that word qualify.
          </p>
        </div>

        <!-- Virtual Number -->
        <div class="form-group">
          <label for="sender_id">Virtual Number</label>
          <select v-model="instance.sender_id" class="form-control" id="sender_id" required>
            <option value="">-- Select a virtual number --</option>
            <% if (sender_ids && sender_ids['Virtual Number'] && sender_ids['Virtual Number'].length) { %>
              <% sender_ids['Virtual Number'].forEach(function(num) { %>
                <option value="<%= num %>"><%= num %></option>
              <% }); %>
            <% } %>
          </select>
          <div class="help-text">
            The virtual number to monitor for incoming messages. Saving will automatically
            configure this number to forward inbound SMS to this feeder.
          </div>
        </div>

        <!-- Response Type -->
        <div class="form-group">
          <label for="text_type">Message Filter</label>
          <select v-model="instance.text_type" class="form-control" id="text_type" required>
            <option value="Anything">Any Message</option>
            <option value="Keyword">Specific Keyword</option>
          </select>
          <div class="help-text">
            Choose whether any inbound message qualifies, or only messages containing a specific keyword.
          </div>
        </div>

        <!-- Keyword -->
        <div class="form-group" v-show="instance.text_type === 'Keyword'">
          <label for="keyword">Keyword (comma-separated)</label>
          <input
            type="text"
            v-model="instance.keyword"
            class="form-control"
            id="keyword"
            placeholder="e.g., JOIN, REGISTER, YES"
            v-bind:required="instance.text_type === 'Keyword'">
          <div class="help-text">
            Only messages containing one of these words will qualify (case-insensitive).
            Separate multiple keywords with commas.
          </div>
        </div>

        <div class="section-divider"></div>

        <!-- Custom Object Mapping (read-only, configured in App Settings) -->
        <div class="cdo-mapping-box">
          <h5>Custom Object Mapping</h5>

          <div v-if="hasCdoConfig">
            <div class="cdo-name">
              Custom Object: {{ cdoConfig.name || 'Loading...' }}
            </div>

            <div class="cdo-field-row" v-if="cdoConfig.mobile_field">
              <span class="cdo-field-label">Mobile Number:</span>
              <span class="cdo-field-value">{{ cdoConfig.mobile_field }}</span>
            </div>
            <div class="cdo-field-row" v-if="cdoConfig.email_field">
              <span class="cdo-field-label">Email Address:</span>
              <span class="cdo-field-value">{{ cdoConfig.email_field }}</span>
            </div>
            <div class="cdo-field-row" v-if="cdoConfig.response_field">
              <span class="cdo-field-label">Incoming Message:</span>
              <span class="cdo-field-value">{{ cdoConfig.response_field }}</span>
            </div>
            <div class="cdo-field-row" v-if="cdoConfig.vn_field">
              <span class="cdo-field-label">Virtual Number:</span>
              <span class="cdo-field-value">{{ cdoConfig.vn_field }}</span>
            </div>
            <div class="cdo-field-row" v-if="cdoConfig.title_field">
              <span class="cdo-field-label">Campaign Title:</span>
              <span class="cdo-field-value">{{ cdoConfig.title_field }}</span>
            </div>

            <div class="help-text" style="margin-top: 15px; padding-top: 10px; border-top: 1px solid #dee2e6;">
              Inbound message data will be logged to this custom object automatically.
              To change these mappings go to <strong>Application Settings</strong>.
            </div>
          </div>

          <div v-else>
            <div class="cdo-no-config">No custom object configured</div>
            <div class="help-text" style="text-align: center; margin-top: 10px;">
              Inbound messages will be tracked internally but not logged to a custom object.
              To enable custom object logging, configure it in <strong>Application Settings</strong>.
            </div>
          </div>
        </div>

        <div class="section-divider"></div>

        <!-- Activity Summary -->
        <div class="report-section">
          <h5>Activity Summary</h5>

          <div v-if="loadingStats" class="loading-spinner">
            <div class="spinner"></div>
            <p>Loading statistics...</p>
          </div>

          <div v-else class="report-stats">
            <div class="stat-card success">
              <span class="stat-number">{{ stats.total }}</span>
              <span class="stat-label">Total Received</span>
            </div>
            <div class="stat-card">
              <span class="stat-number">{{ stats.today }}</span>
              <span class="stat-label">Today</span>
            </div>
            <div class="stat-card warning">
              <span class="stat-number">{{ stats.optouts }}</span>
              <span class="stat-label">Opt-outs</span>
            </div>
          </div>

          <div class="report-actions">
            <button type="button" @click="loadStats" class="btn btn-default" :disabled="loadingStats">
              <span v-if="loadingStats">
                <span class="spinner spinner-sm"></span>Refreshing...
              </span>
              <span v-else>Refresh</span>
            </button>
          </div>
        </div>

        <button
          id="btnSave"
          type="button"
          v-on:click="saveInstance()"
          class="btn"
          v-bind:disabled="!isValid || saving">
          <span v-if="saving">
            <span class="spinner spinner-sm"></span>SAVING...
          </span>
          <span v-else>SAVE CONFIGURATION</span>
        </button>

        <div v-if="status.success || status.error"
             v-bind:class="{ 'alert-success': status.success, 'alert-danger': status.error, 'in': fade }"
             class="alert fade"
             role="alert"
             style="margin-top: 20px;">
          {{ status.success || status.error }}
        </div>
      </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/vue@2.6.11"></script>
    <script src="/eloqua-service/assets/js/axios.min.js"></script>

    <script type="text/javascript">
      var instance = <%- JSON.stringify(instance) %>;
      var consumer = <%- JSON.stringify(consumer) %>;

      var app = new Vue({
        el: '#incomingsmsfeeder',
        data: {
          instance: {
            sender_id:  instance.sender_id  || '',
            text_type:  instance.text_type  || 'Anything',
            keyword:    instance.keyword    || '',
            instanceId: instance.instanceId || '',
            installId:  instance.installId  || consumer.installId,
            SiteId:     instance.SiteId     || consumer.SiteId
          },
          consumer: consumer,
          status: {},
          fade: false,
          saving: false,
          loadingStats: false,
          stats: { total: 0, today: 0, optouts: 0 },
          cdoConfig: {
            name: null,
            mobile_field:   null,
            email_field:    null,
            response_field: null,
            vn_field:       null,
            title_field:    null
          }
        },

        computed: {
          isValid: function () {
            if (!this.instance.sender_id) return false;
            if (this.instance.text_type === 'Keyword' && !this.instance.keyword.trim()) return false;
            return true;
          },
          hasCdoConfig: function () {
            return !!(
              this.consumer.actions &&
              this.consumer.actions.incomingsms &&
              this.consumer.actions.incomingsms.custom_object_id
            );
          }
        },

        methods: {
          saveInstance: function () {
            var vm = this;

            if (!this.isValid) {
              this.showMessage('error', 'Please select a virtual number');
              return;
            }

            vm.saving = true;

            var data = {
              instance: {
                instanceId: vm.instance.instanceId,
                installId:  vm.instance.installId,
                SiteId:     vm.instance.SiteId,
                feederType: 'incoming_sms',
                sender_id:  vm.instance.sender_id,
                text_type:  vm.instance.text_type,
                keyword:    vm.instance.text_type === 'Keyword' ? vm.instance.keyword.trim() : null
              }
            };

            axios.post(location.pathname + location.search, data)
              .then(function (response) {
                vm.showMessage('success', 'Configuration saved. Virtual number is now forwarding inbound SMS to this feeder.');
                vm.loadStats();
                setTimeout(function () {
                  if (window.opener) window.close();
                }, 2000);
              })
              .catch(function (error) {
                var msg = (error.response && error.response.data && error.response.data.message)
                  ? error.response.data.message
                  : 'Failed to save configuration';
                vm.showMessage('error', msg);
              })
              .finally(function () {
                vm.saving = false;
              });
          },

          loadStats: function () {
            var vm = this;

            if (!vm.instance.instanceId) return;

            vm.loadingStats = true;

            axios.get(
              '/eloqua/feeder/inbound/stats/' + vm.instance.instanceId,
              { params: { installId: vm.instance.installId } }
            )
              .then(function (response) {
                vm.stats = response.data.stats || { total: 0, today: 0, optouts: 0 };
              })
              .catch(function () {
                vm.stats = { total: 0, today: 0, optouts: 0 };
              })
              .finally(function () {
                vm.loadingStats = false;
              });
          },

          loadCdoDetails: function () {
            var vm = this;

            if (!this.hasCdoConfig) return;

            var cdoId = this.consumer.actions.incomingsms.custom_object_id;
            var actions = this.consumer.actions.incomingsms;

            vm.cdoConfig = {
              name:           'Loading...',
              mobile_field:   actions.mobile_field   || null,
              email_field:    actions.email_field    || null,
              response_field: actions.response_field || null,
              vn_field:       actions.vn_field       || null,
              title_field:    actions.title_field    || null
            };

            axios.get(
              '/eloqua/action/ajax/customobject/' +
              vm.consumer.installId + '/' +
              vm.consumer.SiteId + '/' +
              cdoId
            )
              .then(function (response) {
                vm.cdoConfig.name = response.data.name || 'Custom Object';
              })
              .catch(function () {
                vm.cdoConfig.name = 'Custom Object (ID: ' + cdoId + ')';
              });
          },

          showMessage: function (type, message) {
            this.status = {};
            this.status[type] = message;
            this.fade = true;
            var vm = this;
            setTimeout(function () {
              vm.fade = false;
              setTimeout(function () { vm.status = {}; }, 500);
            }, 4000);
          }
        },

        mounted: function () {
          this.loadCdoDetails();
          this.loadStats();
        }
      });
    </script>
  </body>
</html>
